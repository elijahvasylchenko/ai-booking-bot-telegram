    {
      "parameters": {
        "jsCode": "const response = $input.all()[0].json;\nconst services = response.data;\n\nif (!services || !Array.isArray(services)) {\n  return [{ json: { text: \"Service list is currently unavailable 😔\" } }];\n}\n\nlet message = \"✨ *Our services & prices* ✨\\n\\n\";\n\nservices.forEach((item, index) => {\n  const title = item.title || \"No name\";\n  const duration = item.lengthInMinutes || \"—\";\n  const price = item.description || \"Price on request\";\n  message += `${index + 1}. *${title}*\\n`;\n  message += `⏳ Duration: ${duration} min\\n`;\n  message += `💰 Price: ${price}\\n\\n`;\n});\n\nmessage += \"To book, just write the service name or choose a time! 👇\";\n\nreturn [{ json: { formatted_text: message, services_count: services.length } }];"
      },
